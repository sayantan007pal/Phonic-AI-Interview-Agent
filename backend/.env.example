# ═══════════════════════════════════════════════════════════════════════════════
# Phonic AI Interview Agent - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=phonic_interviews

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ENVIRONMENT=development

# ── URLs ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── LLM Provider ───────────────────────────────────────────────────────────────
# Options: ollama, claude, openai
LLM_PROVIDER=ollama

# Ollama (Local - Free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Voice Pipeline ─────────────────────────────────────────────────────────────
# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# Cartesia (Text-to-Speech)
CARTESIA_API_KEY=
CARTESIA_CUSTOM_VOICE_ID=

# ── Telephony - Telnyx (International) ─────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_CONNECTION_ID_DEFAULT=
TELNYX_DID_US=
TELNYX_DID_UK=
TELNYX_DID_AU=
TELNYX_DID_CA=

# ── Telephony - Ozonetel (India) ───────────────────────────────────────────────
OZONETEL_API_KEY=
OZONETEL_API_URL=https://in1-ccaas-api.ozonetel.com/cloudAgentRestAPI/index.php/AddCampaignBulkDataV4/addBulkData/format/json
OZONETEL_CAMPAIGN_NAME=
OZONETEL_USERNAME=
OZONETEL_CALLBACK_URL=

# ── Telephony - Exotel (India Alternative) ─────────────────────────────────────
INDIA_TELEPHONY_PROVIDER=ozonetel
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_VIRTUAL_NUMBER=

# ── LiveKit (WebRTC) ───────────────────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── AWS (Optional - for recordings) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
SQS_EVALUATION_QUEUE_URL=
